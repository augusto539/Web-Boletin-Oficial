# Sin dominio todavía: sirve por HTTP simple en el puerto 80 (":80" matchea
# cualquier host, incluida la IP pública). Let's Encrypt no puede emitir un
# certificado para una IP desnuda, así que no hay HTTPS automático hasta acá.
#
# Cuando tengas un dominio: reemplazá la línea ":80 {" por "tudominio.com {"
# (sin el bloque http:// de abajo) y Caddy activa TLS automático solo con eso
# — no hace falta tocar nada más.
:80 {
	reverse_proxy app:5050
	encode gzip

	# Los archivos estáticos del build de Vite (con hash en el nombre) se
	# pueden cachear agresivo; el index.html no (Caddy ya evita cachear rutas
	# sin extensión / HTML por default, esto es solo para los assets).
	@static path /assets/*
	header @static Cache-Control "public, max-age=31536000, immutable"
}
