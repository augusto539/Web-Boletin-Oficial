# Plantilla del .env que vive en el servidor (NUNCA en el repo). Copiar a
# ".env" junto al docker-compose.prod.yml y completar con valores reales.
#
# Generar contraseñas/secretos con: openssl rand -base64 32

# Imagen publicada por CI en GitHub Container Registry (ver
# .github/workflows/deploy.yml). El workflow de deploy sobreescribe esta
# variable con el tag del commit recién buildeado antes de levantar.
APP_IMAGE=ghcr.io/augusto539/web-boletin-oficial:latest

# Contraseña del rol owner (boletin_admin). Los roles boletin_api/boletin_auth
# ya se crean con sus propias contraseñas dentro de las migraciones
# (007_rls.sql, 022_sesiones_y_rol_auth.sql) — deben coincidir con estas dos:
POSTGRES_PASSWORD=
BOLETIN_API_PASSWORD=
BOLETIN_AUTH_PASSWORD=

JWT_SECRET=

# Dominio propio verificado en Resend (ingcome.com.ar).
RESEND_API_KEY=
MAIL_FROM=INGcome <no-responder@ingcome.com.ar>

SITE_URL=https://ingcome.com.ar

# Google Analytics (opcional)
VITE_GA_ID=
