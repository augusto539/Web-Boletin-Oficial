# Conexión con permisos de owner, usada solo por las migraciones y el seed.
DATABASE_URL=postgres://boletin_admin:boletin_dev_password@localhost:5432/boletin_sociedades

# Conexión con permisos restringidos, usada por PostGraphile para servir la API.
# El rol boletin_api solo puede leer/escribir lo que las políticas RLS permiten
# (nunca ve filas con oculta = true).
DATABASE_URL_API=postgres://boletin_api:boletin_api_dev_password@localhost:5432/boletin_sociedades

# Conexión del backend de auth (login/registro). Único rol que puede tocar las
# tablas usuarios y sesiones.
DATABASE_URL_AUTH=postgres://boletin_auth:boletin_auth_dev_password@localhost:5432/boletin_sociedades

# Secreto para firmar los JWT de acceso. En producción tiene que ser un valor
# largo y aleatorio guardado en un secret manager, nunca en el repo.
JWT_SECRET=dev_jwt_secret_cambiar_en_produccion

# Mail transaccional (bienvenida, reset de contraseña). Dominio propio
# verificado en Resend (ingcome.com.ar).
RESEND_API_KEY=
MAIL_FROM=INGcome <no-responder@ingcome.com.ar>
FRONTEND_URL=http://localhost:5173

PORT=5050
CORS_ORIGIN=http://localhost:5173

# URL pública del sitio (para canonical/OG/sitemap). En prod, el dominio real.
SITE_URL=http://localhost:5050

# Google Analytics 4 (Measurement ID, formato G-XXXXXXXXXX). Vacío = no carga
# gtag.js. Además solo se activa en build de producción (ver
# frontend/src/lib/analytics.ts), así que en desarrollo no hace falta sacarla.
VITE_GA_ID=
