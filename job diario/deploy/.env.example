# Copiar a ".env" (sin ".example") en esta misma carpeta y completar con los
# valores reales. NUNCA commitear el ".env" real a git (agregar "job diario/deploy/.env"
# a .gitignore si todavía no está).

ANTHROPIC_API_KEY=

# Misma base que usa la app web — conectar con el rol boletin_admin (owner,
# bypassea RLS), NO con boletin_api ni boletin_auth (esos son de solo lectura /
# solo auth y no tienen permiso de escritura sobre sociedades/personas/etc).
DATABASE_URL=postgres://boletin_admin:CAMBIAR_PASSWORD@localhost:5432/boletin_sociedades

# Alerta de fallo por mail (reutiliza la cuenta Resend que ya usa la app web,
# ver RESEND_API_KEY en el docker-compose.yml del repo "WEB Info Boletin Oficial").
RESEND_API_KEY=
ALERTA_EMAIL_TO=
ALERTA_EMAIL_FROM=Job Diario <onboarding@resend.dev>
